<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="bookRepository" class="com.library.repository.BookRepository"/>

    <!-- Constructor injection: wires bookRepository in via BookService's constructor -->
    <bean id="bookService" class="com.library.service.BookService">
        <constructor-arg ref="bookRepository"/>
    </bean>

    <!--
      Setter injection alternative, shown for comparison.
      BookService.setBookRepository(...) exists specifically so it CAN be
      wired this way -- in practice you'd choose constructor injection OR
      setter injection for a given dependency, not both, since wiring the
      same property twice is redundant. Uncomment to try it instead of the
      constructor-arg bean above (and give it a different id, or remove the
      bean above, to avoid defining "bookService" twice).

      <bean id="bookService" class="com.library.service.BookService">
          <property name="bookRepository" ref="bookRepository"/>
      </bean>
    -->

</beans>
